    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "wrangler:dev": "wrangler dev",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "lucide-svelte": "^1.0.1",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@testing-library/svelte": "^5.0.0",
    "@vitest/ui": "^2.0.0",
    "jsdom": "^24.0.0",
    "playwright": "^1.40.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0",
    "wrangler": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
